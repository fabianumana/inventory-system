@model SCS.ViewModels.IngresosVM

@{
    ViewData["Title"] = "Listado de Ingresos";
    Layout = "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SCS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SCS.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/estilo.css" asp-append-version="true" />
    <style>
        html, body {
            height: 100%;
            margin: 0;
            display: flex;
            flex-direction: column;
            background-color: #2271b3;
            font-family: 'Roboto', sans-serif;
        }

        .container {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .card {
            max-width: 1100px;
            width: 100%;
            background-color: #fff;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .card-header {
            color: #000;
            font-weight: bold;
            text-align: center;
            padding: 20px;
        }

        .card-body {
            padding: 20px;
        }

        .table-responsive {
            margin-top: 20px;
        }

        .table-striped tbody tr:nth-of-type(odd) {
            background-color: #f9f9f9;
        }

        footer {
            text-align: center;
            padding: 10px;
            background-color: rgba(255, 255, 255, 0.8);
            width: 100%;
            position: sticky;
            bottom: 0;
        }

        .btn-primary {
            background-color: #3498db;
            border: none;
            font-size: 14px;
            font-weight: bold;
        }

            .btn-primary:hover {
                background-color: #2980b9;
            }

        .btn-secondary {
            background-color: #7f8c8d;
            border: none;
            font-size: 14px;
            font-weight: bold;
        }

            .btn-secondary:hover {
                background-color: #34495e;
            }

        .text-muted {
            color: #7f8c8d;
        }

        .table-striped tbody tr:hover {
            background-color: #e9ecef;
        }

        .d-flex .btn {
            flex: 1;
            margin: 0 5px;
        }

        .btn-sm {
            font-size: 14px;
            padding: 5px 10px;
        }

        .table th, .table td {
            vertical-align: middle;
        }

        .logo-container {
            position: fixed;
            top: 20px;
            right: 40px;
            z-index: 1000;
            padding: 5px;
            border-radius: 8px;
        }

            .logo-container img {
                width: 230px;
                height: auto;
            }

        .d-flex .btn {
            flex-grow: 1;
            text-align: center;
            white-space: nowrap;
        }
    </style>
</head>
<body>
    <div class="logo-container">
        <img src="/imagen/logo.png" alt="Intel Logo" />
    </div>
    <div class="container content-spacing">
        <div class="card">
            <div class="card-header text-center">
                <h2>Listado de Ingresos</h2>
            </div>
            <div class="card-body">
                <form method="get" class="mb-4">
                    <div class="row">
                        <div class="col-md-4">
                            <input type="text" name="parte" value="@Model.FiltroParte" class="form-control" placeholder="Buscar por nombre de parte" />
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary">Buscar</button>
                        </div>
                    </div>
                </form>

                <a class="btn btn-primary mb-3" href="@Url.Action("Create", "Ingresos")">
                    <i class="fa-solid fa-plus"></i> Crear Nuevo Ingreso
                </a>

                @if (Model.Ingresos.Any())
                {
                    <table class="table table-striped table-hover table-bordered">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Parte</th>
                            <th>Serial</th>
                            <th>Cantidad</th>
                            <th>Motivo</th>
                            <th>Usuario</th>
                            <th>Departamento</th>
                            <th>Fecha de Ingreso</th>
                            <th>Opciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ingreso in Model.Ingresos)
                        {
                            <tr>
                                <td>@ingreso.Id_transaccion_ing</td>
                                <td>@ingreso.Parte?.Nombre</td>
                                <td>@ingreso.Numero_serial</td>
                                <td>@ingreso.Cantidad</td>
                                <td>@ingreso.Motivo</td>
                                <td>@ingreso.Usuario_ingreso</td>
                                <td>@ingreso.Departamento</td>
                                <td>@ingreso.Fecha_ingreso?.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <a href="@Url.Action("Details", new { id = ingreso.Id_transaccion_ing })" class="btn btn-sm btn-primary flex-grow-1 text-center">
                                                <i class="fa-solid fa-eye"></i> Ver
                                            </a>
                                            <a href="@Url.Action("Edit", new { id = ingreso.Id_transaccion_ing })" class="btn btn-sm btn-warning flex-grow-1 text-center">
                                                <i class="fa-solid fa-pen"></i> Editar
                                            </a>
                                            <a href="@Url.Action("Disable", new { id = ingreso.Id_transaccion_ing })" class="btn btn-sm btn-danger flex-grow-1 text-center">
                                                <i class="fa-solid fa-trash"></i> Deshabilitar
                                            </a>
                                        </div>
                                    </td>
                            </tr>
                        }
                    </tbody>
                </table>
                }
                else
                {
                    <p>No se encontraron ingresos.</p>
                }

                <ul>
                    <li><a class="btn btn-secondary btn-custom mb-2" asp-controller="Home" asp-action="Inicio"><i class="fa-solid fa-rotate-left"></i> Regresar</a></li>
                </ul>
            </div>
        </div>
    </div>
    <footer class="border-top footer text-muted">
            <strong>&copy; 2024 - SCS</strong>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://kit.fontawesome.com/5a833361a2.js" crossorigin="anonymous"></script>
</body>
</html>
