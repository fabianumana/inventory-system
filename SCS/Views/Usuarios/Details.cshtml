@model SCS.Models.Usuarios

@{
    ViewData["Title"] = "Detalles del Perfil";
    Layout = "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SCS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SCS.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/estilo.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" integrity="sha512-Fo3rlrZj/k7ujTnHq6Nz4Mb+k6bM2T50i29Qe4n5cG3ZDZl0zcn4LY0GHav1vF3lZ+3mDf0qf68r5ZgJ0Zf8Eg==" crossorigin="anonymous" referrerpolicy="no-referrer" /> 
    <style>
        html, body {
            height: 100%;
            margin: 0;
            display: flex;
            flex-direction: column;
        }

        .content-spacing {
            flex: 1; 
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            box-sizing: border-box;
        }

        footer {
            text-align: center;
            padding: 10px;
            font-size: 14px;
            background-color: rgba(255, 255, 255, 0.8);
            box-shadow: 0 -1px 5px rgba(0, 0, 0, 0.1);
            width: 100%;
            position: relative;
        }

        .logo-container {
            position: fixed;
            top: 20px;
            right: 40px;
            z-index: 1000;
            padding: 5px;
            border-radius: 8px;
        }

            .logo-container img {
                width: 230px;
                height: auto;
            }
    </style>
</head>
<body>
    <div class="logo-container">
        <img src="/imagen/logo.png" alt="Intel Logo" />
    </div>
    <div class="container content-spacing">
        <div class="card">
            <div class="card-header text-center">
                <h2>Detalles del Perfil</h2>
            </div>
            <div class="card-body">
                <p><strong>Nombre de Usuario:</strong> @Model.User</p>
                <p><strong>ID:</strong> @Model.WWID</p>
                <p><strong>Apellidos:</strong> @Model.Apellidos</p>
                <p><strong>Correo:</strong> @Model.Correo</p>
                <p><strong>Teléfono:</strong> @Model.Telefono</p>
                <p><strong>Departamento:</strong> @Model.Departamento</p>
                <p><strong>Superior:</strong> @Model.Superior</p>

                <div class="d-flex gap-2">
                    <a class="btn btn-warning btn-sm flex-fill" href="@Url.Action("Edit", new { id = Model.Id_perfiles })">
                        <i class="fa-solid fa-pen"></i> Editar
                    </a>

                    <a class="btn btn-secondary btn-sm flex-fill" href="@Url.Action("Index")">
                        <i class="fa-solid fa-rotate-left"></i> Volver al Listado
                    </a>
                </div>
            </div>
        </div>
    </div>
    <footer class="border-top footer text-muted">
            <strong>&copy; 2024 - SCS</strong>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://kit.fontawesome.com/5a833361a2.js" crossorigin="anonymous"></script>
</body>
</html>