@model SCS.Models.Usuarios

@{
    ViewData["Title"] = "Editar Perfil";
    Layout = "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SCS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SCS.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/estilo.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" integrity="sha512-Fo3rlrZj/k7ujTnHq6Nz4Mb+k6bM2T50i29Qe4n5cG3ZDZl0zcn4LY0GHav1vF3lZ+3mDf0qf68r5ZgJ0Zf8Eg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style>
        .logo-container {
            position: fixed;
            top: 20px;
            right: 40px;
            z-index: 1000;
            padding: 5px;
            border-radius: 8px;
        }

            .logo-container img {
                width: 230px;
                height: auto;
            }
    </style>
</head>
<body>
    <div class="logo-container">
        <img src="/imagen/logo.png" alt="Intel Logo" />
    </div>
    <div class="container content-spacing">
        <div class="card">
            <div class="card-header text-center">
                <h2>Editar Perfil</h2>
            </div>
            <a class="btn btn-secondary" href="@Url.Action("DetallesUsuario", "Administracion")">
                <i class="fa-solid fa-rotate-left"></i> Regresar al Perfil
            </a>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id_perfiles" />

                    <div class="mb-3">
                        <label asp-for="User"></label>
                        <input asp-for="User" class="form-control" readonly/>
                        <span asp-validation-for="User" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="WWID"></label>
                        <input asp-for="WWID" class="form-control" readonly/>
                        <span asp-validation-for="WWID" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Apellidos"></label>
                        <input asp-for="Apellidos" class="form-control" readonly/>
                        <span asp-validation-for="Apellidos" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Correo"></label>
                        <input asp-for="Correo" class="form-control" readonly/>
                        <span asp-validation-for="Correo" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Telefono"></label>
                        <input asp-for="Telefono" class="form-control" />
                        <span asp-validation-for="Telefono" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Departamento"></label>
                        <input asp-for="Departamento" class="form-control" />
                        <span asp-validation-for="Departamento" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Superior"></label>
                        <input asp-for="Superior" class="form-control" />
                        <span asp-validation-for="Superior" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-save"></i> Guardar Cambios
                    </button>
                    <a class="btn btn-secondary" href="@Url.Action("Index", "Usuarios")">
                        <i class="fa-solid fa-rotate-left"></i> Cancelar
                    </a>
                </form>

            </div>
        </div>
    </div>
    <footer class="border-top footer text-muted">
            <strong>&copy; 2024 - SCS</strong>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://kit.fontawesome.com/5a833361a2.js" crossorigin="anonymous"></script>
</body>
</html>
