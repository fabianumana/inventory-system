@model SCS.ViewModels.LoginVM
@{
    ViewData["Title"] = "Login";
    Layout = "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SCS.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" integrity="sha512-Fo3rlrZj/k7ujTnHq6Nz4Mb+k6bM2T50i29Qe4n5cG3ZDZl0zcn4LY0GHav1vF3lZ+3mDf0qf68r5ZgJ0Zf8Eg==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <script>
        window.history.forward();
        function noBack() {
            window.history.forward();
        }
        window.onload = noBack;
        window.onpageshow = function (evt) {
            if (evt.persisted) noBack();
        }
        window.onunload = function () { null };
    </script>
    <style>
        .logo-container {
            position: fixed;
            top: 20px;
            right: 40px;
            z-index: 1000;
            padding: 5px;
            border-radius: 8px;
        }

            .logo-container img {
                width: 230px;
                height: auto;
            }
    </style>
</head>
<body>
    <div class="logo-container">
        <img src="/imagen/logo.png" alt="Intel Logo" />
    </div>
    <div class="container">
        <div class="login-card">
            <div class="card">
                <div class="card-header">
                    <div class="text-center">
                        <i class="fas fa-user-shield logo-icon"></i>
                        <h5>Iniciar Sesión</h5>
                    </div>
                </div>
                <div class="card-body">
                    <form asp-controller="Acceso" asp-action="Login" method="post">
                       <div>
                          <input class="form-control" type="email" placeholder="Correo Electrónico" required asp-for="Correo" />
                           <span asp-validation-for="Correo" class="text-danger"></span>
                       </div>

                       <div>
                          <input class="form-control" type="password" placeholder="Contraseña" required asp-for="Contrasena" minlength="8" />
                          <span asp-validation-for="Contrasena" class="text-danger"></span>
                       </div>

                       @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                       <div class="d-grid">
                           <button class="btn btn-primary" type="submit">
                              <i class="fas fa-sign-in-alt"></i> Ingresar
                           </button>
                       </div>

                       @if (ViewData["Mensaje"] != null)
                       {
                          <div class="alert alert-danger" role="alert">
                              @ViewData["Mensaje"]
                          </div>
                       }

                       <div class="text-center mt-3">
                          <strong>¿No tienes una cuenta?</strong>
                          <a asp-controller="Acceso" asp-action="Registrar">
                             <i class="fas fa-user-plus"></i> Regístrate
                          </a>
                          <br />
                          <strong>¿Olvidaste tu contraseña?</strong>
                          <a asp-controller="Cuenta" asp-action="ContraseñaOlvidada">
                             <i class="fas fa-lock"></i> Recuperar Contraseña
                          </a>
                       </div>

                       <div class="footer-text">
                        <i class="fas fa-envelope"></i> fabianmj1236@gmail.com | <i class="fas fa-phone-alt"></i> 8751-1180
                       </div>
                    </form>
                    </div>
            </div>
        </div>
    </div>
    <footer class="border-top footer text-muted">
        <div class="container-footer">
            <strong>&copy; 2024 - SCS</strong>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://kit.fontawesome.com/5a833361a2.js" crossorigin="anonymous"></script>
</body>
</html>
