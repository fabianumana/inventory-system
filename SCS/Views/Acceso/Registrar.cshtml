@model SCS.ViewModels.PerfilesVM;
@{
    ViewData["Title"] = "Registro";
    Layout = "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registrar</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/SCS.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" integrity="sha512-Fo3rlrZj/k7ujTnHq6Nz4Mb+k6bM2T50i29Qe4n5cG3ZDZl0zcn4LY0GHav1vF3lZ+3mDf0qf68r5ZgJ0Zf8Eg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script>
        window.history.forward();
        function noBack() {
            window.history.forward();
        }
        window.onload = noBack;
        window.onpageshow = function (evt) {
            if (evt.persisted) noBack();
        }
        window.onunload = function () { null };
    </script>
    <style>
        html, body {
            height: 100%;
            margin: 0;
            display: flex;
            flex-direction: column;
            background-color: #2271b3;
            overflow: auto;
        }

        .container {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            align-items: center;
            padding: 20px;
            padding-top: 40px; 
            box-sizing: border-box;
            min-height: 100vh;
        }

        .register-card {
            width: 100%;
            max-width: 500px;
        }

        footer {
            position: fixed;
            bottom: 0;
            width: 100%;
            background-color: rgba(255, 255, 255, 0.9);
            text-align: center;
            padding: 10px 0;
            box-shadow: 0 -1px 5px rgba(0, 0, 0, 0.1);
        }

        .footer-text {
            font-size: 14px;
        }

        .logo-container {
            position: fixed;
            top: 20px;
            right: 40px; 
            z-index: 1000;
            padding: 5px;
            border-radius: 8px;
        }

            .logo-container img {
                width: 230px; 
                height: auto;
            }
    </style>
</head>
<body>
    <div class="logo-container">
        <img src="/imagen/logo.png" alt="Intel Logo" />
    </div>
    <div class="container">
            <div class="register-card">
                <div class="card">
                    <div class="card-header">
                        <i class="fas fa-user-plus logo-icon"></i>
                        <h5>Registrarse</h5>
                    </div>
                    <div class="card-body">
                        <form asp-controller="Acceso" asp-action="Registrar" method="post">
                            <div class="mb-3">
                                <input class="form-control" type="text" placeholder="Usuario" required asp-for="Usuario" />
                                <span asp-validation-for="Usuario" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <input class="form-control" type="text" placeholder="WWID" required asp-for="WWID" />
                                <span asp-validation-for="WWID" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <input class="form-control" type="email" placeholder="Correo Electrónico" required asp-for="Correo" />
                                <span asp-validation-for="Correo" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <input class="form-control" type="password" placeholder="Contraseña" required asp-for="Contrasena" minlength="8" id="Contrasena" />
                                <span asp-validation-for="Contrasena" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <input class="form-control" type="password" placeholder="Confirmar Contraseña" required asp-for="Confirmacion" id="Confirmacion" />
                                <span asp-validation-for="Confirmacion" class="text-danger"></span>
                            </div>
                            <div class="mb-3 form-check">
                                <input class="form-check-input" type="checkbox" id="mostrar" onclick="MostrarContrasena()" />
                                <label class="form-check-label" for="mostrar">Mostrar contraseñas</label>
                            </div>
                            <div class="mb-3">
                                <input class="form-control" type="text" placeholder="Apellidos" required asp-for="Apellidos" />
                                <span asp-validation-for="Apellidos" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <input class="form-control" type="text" placeholder="Teléfono" required asp-for="Telefono" pattern="\d{4}-\d{4}" title="El teléfono debe tener el formato 1234-5678." />
                                <span asp-validation-for="Telefono" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <input class="form-control" type="text" placeholder="Departamento" required asp-for="Departamento" />
                                <span asp-validation-for="Departamento" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <select class="form-control" required asp-for="Superior">
                                    <option value="" disabled selected>Seleccionar Manager</option>
                                    <option value="Nathalia">Nathalia</option>
                                    <option value="Gabriela">Gabriela</option>
                                </select>
                                <span asp-validation-for="Superior" class="text-danger"></span>
                            </div>

                            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                            <div class="d-grid mb-3">
                                <button class="btn btn-primary" type="submit">
                                    <i class="fas fa-user-plus"></i> Registrarse
                                </button>
                            </div>

                            @if (ViewData["Mensaje"] != null)
                            {
                                <div class="alert alert-danger" role="alert">
                                    @ViewData["Mensaje"]
                                </div>
                            }

                            <div class="text-center mt-3">
                                ¿Ya tienes una cuenta? <a asp-controller="Acceso" asp-action="Login"><i class="fas fa-sign-in-alt"></i> Iniciar sesión</a>
                            </div>

                            <div class="footer-text text-center mt-3">
                                <i class="fas fa-envelope"></i> fabianmj1236@gmail.com | <i class="fas fa-phone-alt"></i> 8751-1180
                            </div>
                        </form>
                    </div>
                </div>
            </div>
    </div>
    <footer class="border-top footer text-muted">
            <strong>&copy; 2024 - SCS</strong>
    </footer>
    <script>
        function MostrarContrasena() {
            var CampoContraseña = document.getElementById("Contrasena");
            var ConfirmarContraseña = document.getElementById("Confirmacion");

            if (CampoContraseña.type === "password") {
                CampoContraseña.type = "text";
                ConfirmarContraseña.type = "text";
            } else {
                CampoContraseña.type = "password";
                ConfirmarContraseña.type = "password";
            }
        }
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://kit.fontawesome.com/5a833361a2.js" crossorigin="anonymous"></script>
</body>
</html> 