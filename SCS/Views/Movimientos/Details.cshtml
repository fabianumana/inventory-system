@model SCS.Models.BitacoraMovimientos

@{
    ViewData["Title"] = "Detalles del Movimiento";
    Layout = "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SCS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SCS.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/estilo.css" asp-append-version="true" />
    <style>
        .logo-container {
            position: fixed;
            top: 20px;
            right: 40px;
            z-index: 1000;
            padding: 5px;
            border-radius: 8px;
        }

            .logo-container img {
                width: 230px;
                height: auto;
            }
    </style>
</head>
<body>
    <div class="logo-container">
        <img src="/imagen/logo.png" alt="Intel Logo" />
    </div>
    <div class="container mt-5">
        <div class="card">
            <div class="card-header">
                <h2>Detalles del Movimiento</h2>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">ID Movimiento</dt>
                    <dd class="col-sm-9">@Model.Id_movimientos</dd>

                    <dt class="col-sm-3">ID Perfil</dt>
                    <dd class="col-sm-9">@Model.Id_perfi</dd>

                    <dt class="col-sm-3">Tipo Acción</dt>
                    <dd class="col-sm-9">@Model.Tipo_accion</dd>

                    <dt class="col-sm-3">Descripción</dt>
                    <dd class="col-sm-9">@Model.Descripcion</dd>

                    <dt class="col-sm-3">Fecha Acción</dt>
                    <dd class="col-sm-9">@Model.Fecha_accion?.ToString("dd/MM/yyyy")</dd>
                </dl>

                <a href="@Url.Action("Index")" class="btn btn-primary"> <i class="fa-solid fa-rotate-left"></i> Volver al Listado</a>
            </div>
        </div>
    </div>
    <footer class="border-top footer text-muted">
            <strong>&copy; 2024 - SCS</strong>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://kit.fontawesome.com/5a833361a2.js" crossorigin="anonymous"></script>
</body>
</html>