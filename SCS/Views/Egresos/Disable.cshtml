@model SCS.Models.Egresos

@{
    ViewData["Title"] = "Deshabilitar Egreso";
    Layout = ""; 
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SCS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SCS.styles.css" asp-append-version="true" />
    <style>
        .logo-container {
            position: fixed;
            top: 20px;
            right: 40px;
            z-index: 1000;
            padding: 5px;
            border-radius: 8px;
        }

            .logo-container img {
                width: 230px;
                height: auto;
            }

        .card {
            max-width: 600px;
            margin: auto;
            padding: 50px;
        }

        .card-header {
            text-align: center;
            font-size: 1.8rem;
            font-weight: bold;
        }

        .card-body dl dt {
            font-weight: bold;
            font-size: 1rem;
        }

        .card-body dl dd {
            font-size: 1rem;
            margin-bottom: 10px;
        }

        .btn {
            font-size: 1rem;
        }
    </style>
</head>
<body>
    <div class="logo-container">
        <img src="/imagen/logo.png" alt="Intel Logo" />
    </div>
    <div class="container mt-5">
        <div class="card">
            <div class="card-header">
                <h2>Deshabilitar Egreso</h2>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">ID Transacción</dt>
                    <dd class="col-sm-8">@Model.Id_transaccion_eg</dd>

                    <dt class="col-sm-4">Parte</dt>
                    <dd class="col-sm-8">@Model.Parte?.Nombre</dd>

                    <dt class="col-sm-4">Cantidad</dt>
                    <dd class="col-sm-8">@Model.Cantidad</dd>

                    <dt class="col-sm-4">Usuario de Salida</dt>
                    <dd class="col-sm-8">@Model.Usuario_salida</dd>

                    <dt class="col-sm-4">Departamento</dt>
                    <dd class="col-sm-8">@Model.Departamento</dd>

                    <dt class="col-sm-4">Motivo</dt>
                    <dd class="col-sm-8">@Model.Motivo</dd>

                    <dt class="col-sm-4">Fecha de Salida</dt>
                    <dd class="col-sm-8">@Model.Fecha_salida?.ToShortDateString()</dd>
                </dl>

                <form asp-action="DisableConfirmed" method="post">
                    <input type="hidden" name="id" value="@Model.Id_transaccion_eg" />
                    <button type="submit" class="btn btn-danger w-100 mb-2"><i class="fa-solid fa-trash"></i>Confirmar Deshabilitación</button>
                    <a href="@Url.Action("Index", "Egresos")" class="btn btn-secondary w-100"><i class="fa-solid fa-arrow-left"></i>Cancelar</a>
                </form>
            </div>
        </div>
    </div>
    <footer class="border-top footer text-muted">
            <strong>&copy; 2024 - SCS</strong>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://kit.fontawesome.com/5a833361a2.js" crossorigin="anonymous"></script>
</body>
</html>
