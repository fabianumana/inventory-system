@model SCS.Models.Objetos

@{
    ViewData["Title"] = "Detalles del Objeto";
    Layout = "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HTS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SCS.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/estilo.css" asp-append-version="true" />
    <style>
        .logo-container {
            position: fixed;
            top: 20px;
            right: 40px;
            z-index: 1000;
            padding: 5px;
            border-radius: 8px;
        }

            .logo-container img {
                width: 230px;
                height: auto;
            }
    </style>
</head>
<body>
    <div class="logo-container">
        <img src="/imagen/logo.png" alt="Intel Logo" />
    </div>
    <div class="container content-spacing">
        <div class="card">
            <div class="card-header text-center">
                <h2>Detalles del Objeto</h2>
            </div>
            <div class="card-body">
                <ul class="list-group">
                    <li class="list-group-item"><strong>ID del Objeto:</strong> @Model.Id_parte</li>
                    <li class="list-group-item"><strong>Número de Parte:</strong> @Model.Numero_parte</li>
                    <li class="list-group-item"><strong>Nombre:</strong> @Model.Nombre</li>
                    <li class="list-group-item"><strong>Descripción:</strong> @Model.Descripcion</li>
                    <li class="list-group-item"><strong>Fabricante:</strong> @Model.Fabricante</li>
                    <li class="list-group-item"><strong>Cantidad Disponible:</strong> @Model.Cantidad_Disponible</li>
                    <li class="list-group-item"><strong>Ubicación:</strong> @Model.Ubicacion</li>
                    <li class="list-group-item"><strong>Suplidor:</strong> @Model.Suplidor?.Colateral</li>
                </ul>

                <div class="mt-4 text-center">
                    <h5>Foto del Objeto</h5>
                    @if (Model.Archivo != null)
                    {
                        <img src="data:@Model.MimeType;base64,@Convert.ToBase64String(Model.Archivo)" alt="Foto del Objeto" class="img-thumbnail" style="max-width: 300px;" />
                    }
                    else
                    {
                        <p class="text-muted">No hay foto disponible para este objeto.</p>
                    }
                </div>

                <div class="mt-4">
                    <a class="btn btn-secondary" href="@Url.Action("Index", "Objetos")"> <i class="fa-solid fa-rotate-left"></i> Volver al Listado</a>
                </div>
            </div>
        </div>
    </div>
    <footer class="border-top footer text-muted">
            <strong>&copy; 2024 - SCS</strong>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://kit.fontawesome.com/5a833361a2.js" crossorigin="anonymous"></script>
</body>
</html>
