@{
    ViewBag.Title = "Solicitar Rol";
    Layout = "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SCS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SCS.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" integrity="sha512-Fo3rlrZj/k7ujTnHq6Nz4Mb+k6bM2T50i29Qe4n5cG3ZDZl0zcn4LY0GHav1vF3lZ+3mDf0qf68r5ZgJ0Zf8Eg==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <style>
        .logo-container {
            position: fixed;
            top: 20px;
            right: 40px;
            z-index: 1000;
            padding: 5px;
            border-radius: 8px;
        }

            .logo-container img {
                width: 230px;
                height: auto;
            }
    </style>
    <script>
        window.history.forward();
        function noBack() {
            window.history.forward();
        }
        window.onload = noBack;
        window.onpageshow = function (evt) {
            if (evt.persisted) noBack();
        }
        window.onunload = function () { null };
    </script>
</head>
<body>
    <div class="logo-container">
        <img src="/imagen/logo.png" alt="Intel Logo" />
    </div>
    <div class="container">
        <div class="request-card">
            <div class="card">
                <div class="card-header">
                    Solicitar Rol
                </div>
                <div class="card-body">
                    <form method="post" action="@Url.Action("SolicitarRol", "Administracion")">
                        <div class="form-group">
                            <label for="roleId">Rol:</label>
                            <select id="roleId" name="roleId" class="form-control" required>
                                <option value="">Seleccione un rol</option>
                                @if (ViewBag.Roles != null)
                                {
                                    var roles = ViewBag.Roles as IEnumerable<SCS.Models.Roles>;
                                    if (roles != null)
                                    {
                                        foreach (var rol in roles)
                                        {
                                            <option value="@rol.Id_roles">@rol.Rol</option>
                                        }
                                    }
                                    else
                                    {
                                        <option value="">No hay roles disponibles</option>
                                    }
                                }
                                else
                                {
                                    <option value="">No se ha asignado ninguna lista de roles</option>
                                }
                            </select>
                            <span class="text-danger" id="roleError" style="display:none;">Por favor, seleccione un rol.</span>
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fa-solid fa-paper-plane"></i> Enviar Solicitud
                            </button>
                        </div>
                    </form>
                    <div class="d-grid gap-2">
                        <a class="btn btn-secondary mt-2" asp-area="" asp-controller="Home" asp-action="Logout">
                            <i class="fa-solid fa-rotate-left"></i> Regresar
                        </a>
                    </div>

                    @if (ViewData["Mensaje"] != null)
                    {
                        <div class="alert alert-danger mt-3">@ViewData["Mensaje"]</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <footer class="border-top footer text-muted">
            <strong>&copy; 2024 - SCS</strong>
    </footer>
    <script>
        $(document).ready(function () {
            $('#solicitarRolForm').on('submit', function (e) {
                var roleId = $('#roleId').val();
                if (roleId === "") {
                    e.preventDefault();
                    $('#roleError').show();
                } else {
                    $('#roleError').hide();
                }
            });
        });
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://kit.fontawesome.com/5a833361a2.js" crossorigin="anonymous"></script>
</body>
</html>
