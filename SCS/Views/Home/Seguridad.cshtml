@{
    ViewData["Title"] = "Seguridad";
    Layout = "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SCS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SCS.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/estilo.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" integrity="sha512-Fo3rlrZj/k7ujTnHq6Nz4Mb+k6bM2T50i29Qe4n5cG3ZDZl0zcn4LY0GHav1vF3lZ+3mDf0qf68r5ZgJ0Zf8Eg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <script>
        window.history.forward();
        function noBack() {
            window.history.forward();
        }
        window.onload = noBack;
        window.onpageshow = function (evt) {
            if (evt.persisted) noBack();
        }
        window.onunload = function () { null };
    </script>
    <style>
        html, body {
            height: 100%;
            margin: 0;
            display: flex;
            flex-direction: column;
            background-color: #2271b3;
            font-family: 'Roboto', sans-serif;
        }

        .container {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .card {
            width: 100%;
            max-width: 600px;
            background-color: #fff;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .card-header {
            color: #000;
            font-weight: bold;
            text-align: center;
            padding: 15px;
            font-size: 18px;
        }

        .card-body {
            padding: 20px;
        }

        ul {
            list-style-type: none;
            padding: 0;
            margin: 0;
        }

            ul li {
                margin-bottom: 10px;
            }

        .btn-custom {
            width: 100%;
            font-size: 14px;
            font-weight: bold;
            text-align: left;
            padding-left: 10px;
        }

        footer {
            text-align: center;
            padding: 10px;
            background-color: rgba(255, 255, 255, 0.8);
            width: 100%;
            position: sticky;
            bottom: 0;
        }

        .logo-container {
            position: fixed;
            top: 20px;
            right: 40px;
            z-index: 1000;
            padding: 5px;
            border-radius: 8px;
        }

            .logo-container img {
                width: 230px;
                height: auto;
            }
    </style>
</head>
<body>
    <div class="logo-container">
        <img src="/imagen/logo.png" alt="Intel Logo" />
    </div>
    <div class="menu-container">
        <div class="menu-card">
            <div class="card">
                <div class="card-header">
                    Seguridad
                </div>
                <div class="card-body">
                    <ul>
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <h5 class="text-center mb-4 font-roboto">Bienvenido, @User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Name).Select(c => c.Value).SingleOrDefault()</h5>
                        }

                        <li><a class="btn btn-primary btn-custom mb-2" asp-controller="Movimientos" asp-action="Index"><i class="fa-solid fa-angles-right"></i> Bitácora Movimientos</a></li>
                        <li><a class="btn btn-primary btn-custom mb-2" asp-controller="EntradasSalidas" asp-action="Index"><i class="fa-solid fa-door-open"></i> Bitácora Entradas y Salidas</a></li>
                        <li><a class="btn btn-secondary btn-custom mb-2" asp-controller="Home" asp-action="Inicio"><i class="fa-solid fa-rotate-left"></i> Regresar al Inicio</a></li>
                        <li><a class="btn btn-secondary btn-custom mb-2" asp-controller="Home" asp-action="Logout"><i class="fa-solid fa-door-closed"></i> Cerrar Sesión</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <footer class="border-top footer text-muted">
            <strong>&copy; 2024 - SCS</strong>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://kit.fontawesome.com/5a833361a2.js" crossorigin="anonymous"></script>
</body>
</html>